{
  "expo": {
    "name": "WorkaHoric",
    "slug": "workaHoric",
    "scheme": "workahoric",
    "version": "1.0.0",
    "icon": "./src/assets/icons/icon2.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.roblee.workahoric"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/icons/icon2.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1be8587c-b763-40e4-bc30-006f9413e525"
      }
    }
  }
}
