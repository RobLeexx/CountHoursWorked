{
  "expo": {
    "name": "Count Hours Worked",
    "slug": "count-hours-worked",
    "scheme": "counthoursworked",
    "version": "1.0.0",
    "icon": "./src/assets/icons/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.sergio.counthoursworked"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/icons/icon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ebe1a1db-daf2-426f-bc3b-6f14ade47691"
      }
    }
  }
}
